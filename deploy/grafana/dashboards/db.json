{
  "schemaVersion": 38,
  "uid": "database",
  "title": "Database",
  "tags": ["open-git"],
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "organization_id",
        "type": "query",
        "datasource": {"uid": "prometheus"},
        "definition": "label_values(http_requests_total, organization_id)",
        "refresh": 2,
        "includeAll": true,
        "label": "Organization"
      }
    ]
  },
  "panels": [
    {
      "title": "Query p95 Latency",
      "type": "timeseries",
      "datasource": {"uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(db_query_duration_seconds_bucket[5m])) by (query)",
          "refId": "A"
        }
      ],
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8}
    }
  ],
  "version": 1
}
