{
  "schemaVersion": 38,
  "uid": "ci-cd",
  "title": "CI/CD",
  "tags": ["open-git"],
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "organization_id",
        "type": "query",
        "datasource": {"uid": "prometheus"},
        "definition": "label_values(http_requests_total, organization_id)",
        "refresh": 2,
        "includeAll": true,
        "label": "Organization"
      }
    ]
  },
  "panels": [
    {
      "title": "Workflow Runs",
      "type": "timeseries",
      "datasource": {"uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (status) (rate(workflow_runs_total{organization_id=~\"$organization_id\"}[5m]))",
          "refId": "A"
        }
      ],
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8}
    }
  ],
  "version": 1
}
