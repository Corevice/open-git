{
  "schemaVersion": 38,
  "uid": "git-operations",
  "title": "Git Operations",
  "tags": ["open-git"],
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "organization_id",
        "type": "query",
        "datasource": {"uid": "prometheus"},
        "definition": "label_values(http_requests_total, organization_id)",
        "refresh": 2,
        "includeAll": true,
        "label": "Organization"
      }
    ]
  },
  "panels": [
    {
      "title": "Git Ops Rate",
      "type": "timeseries",
      "datasource": {"uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(git_operations_total{organization_id=~\"$organization_id\"}[5m])",
          "refId": "A"
        }
      ],
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8}
    },
    {
      "title": "Git p95 Latency",
      "type": "timeseries",
      "datasource": {"uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{path=~\".*.git.*\"}[5m]))",
          "refId": "A"
        }
      ],
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8}
    }
  ],
  "version": 1
}
