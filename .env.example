# Database
# sqlite (default, dev/small self-hosted) or postgres (production)
DB_TYPE=sqlite
# e.g. ./data/open-git.db
# e.g. postgres://user:pass@localhost:5432/opengit?sslmode=disable
DB_DSN=./data/open-git.db

## Connection pool
DB_AUTO_MIGRATE=false
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1h

# Backend server
PORT=8080

# REQUIRED — JWT signing secret (docker-compose.prod.yml)
JWT_SECRET=change-me-in-production

# Redis (async jobs, caching)
REDIS_ADDR=redis:6379

# MinIO (artifacts, LFS)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin

# REQUIRED — MinIO root password (docker-compose.prod.yml)
MINIO_ROOT_PASSWORD=change-me-in-production
MINIO_SECRET_KEY=minioadmin

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080

# Git repository storage
GIT_STORAGE_PATH=/data/repos

# PostgreSQL (when DB_TYPE=postgres)
POSTGRES_DB=open_git
POSTGRES_USER=open_git

# REQUIRED — PostgreSQL password (docker-compose.prod.yml)
POSTGRES_PASSWORD=change-me-in-production

# Traefik / TLS
DOMAIN=git.example.com

# REQUIRED — Let's Encrypt ACME contact email (docker-compose.prod.yml)
ACME_EMAIL=admin@example.com
TLS_MODE=acme
TLS_CERT_FILE=
TLS_KEY_FILE=
TRUSTED_PROXY_CIDRS=172.16.0.0/12,10.0.0.0/8

# Production image tag (docker-compose.prod.yml)
TAG=latest
