# Database
# sqlite (default, dev/small self-hosted) or postgres (production)
DB_TYPE=sqlite
# e.g. ./data/open-git.db
# e.g. postgres://user:pass@localhost:5432/opengit?sslmode=disable
DB_DSN=./data/open-git.db

## Connection pool
DB_AUTO_MIGRATE=false
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1h

# Backend server
PORT=8080
JWT_SECRET=change-me-in-production

# Redis (async jobs, caching)
REDIS_ADDR=redis:6379

# MinIO (artifacts, LFS)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080

# Git repository storage
GIT_DATA_ROOT=./data/git

# PostgreSQL (when DB_TYPE=postgres)
POSTGRES_DB=open_git
POSTGRES_USER=open_git
POSTGRES_PASSWORD=change-me-in-production

# Traefik (Let's Encrypt)
ACME_EMAIL=admin@example.com
TRAEFIK_ACME_EMAIL=admin@example.com
